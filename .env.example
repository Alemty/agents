# =====================================================
# Job Agent — Variables de Entorno (referencia completa)
# =====================================================
# Copia este archivo a .env o .dev.vars y completa los valores
# NUNCA subas .env o .dev.vars al repo (.gitignore los excluye)

# ─── LinkedIn (para scraping automático) ─────────────
LINKEDIN_EMAIL=alejandrogtzz93@gmail.com
LINKEDIN_PASSWORD=tu_password_aqui

# ─── IA / LLM (para matching mejorado) ──────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── IPFS / Pinata (deploy ENS landing) ──────────────
# Ver: https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=5972755f1f07788608ea
PINATA_API_SECRET=e33e84400d800b7bd7dbdb3c320a78c95369cc5a7c77571c31ef3bf4e6abedfc
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Cloudflare (Wrangler / Deploy) ──────────────────
# Token creado en: https://dash.cloudflare.com/profile/api-tokens
# Plantilla: "Editar Cloudflare Workers" con permisos Workers + D1 Edit
CLOUDFLARE_API_TOKEN=tu_token_cloudflare_aqui
CF_ACCOUNT_ID=792fb5a1c2fb0af960074a1e869db0ed

# ─── Ethereum / Base (firma de txs) ──────────────────
# SOLO para wallet agente de reclaim/postulaciones on-chain
AGENT_PRIVATE_KEY=0x...
RECIPIENT_ADDRESS=0x...

# ─── Worker Secrets (pasar a Cloudflare via wrangler) ─
# npx wrangler secret put PINATA_JWT
# npx wrangler secret put LINKEDIN_EMAIL
# npx wrangler secret put LINKEDIN_PASSWORD
# npx wrangler secret put ANTHROPIC_API_KEY

# ══════════════════════════════════════════════════════════
# REFERENCIA: GitHub Secrets (Settings → Secrets → Actions)
# ══════════════════════════════════════════════════════════
# Para configurar manualmente desde GitHub.com:
#
# 1. Ve a: https://github.com/Alemty/agents/settings/secrets/actions
# 2. Haz clic en "New repository secret"
#
# ┌────────────────────────┬──────────────────────────────────────────────┐
# │ Secret name            │ Value                                        │
# ├────────────────────────┼──────────────────────────────────────────────┤
# │ PINATA_JWT             │ Pega aquí el JWT de Pinata                   │
# ├────────────────────────┼──────────────────────────────────────────────┤
# │ CF_API_TOKEN           │ cfut_Iz0XyhKmCK0Z5TLcVvIc968QQQ5shlbIvkf... │
# │                        │ (el que acabas de crear)                     │
# └────────────────────────┴──────────────────────────────────────────────┘
#
# 3. Pega el valor exacto y guarda.
# 4. El workflow lo usará automáticamente en el próximo push a main.
